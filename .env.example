# Discord
DISCORD_TOKEN=
GUILD_ID=
RECAP_CHANNEL_ID=
# channels PumpDragon will respond in (comma-separated); blank = every channel he can see
ACTIVE_CHANNEL_IDS=
# one role ID, or several comma-separated (any one grants admin); blank = Discord Administrator / server owner only
ADMIN_ROLE_ID=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_MS=8000

# Postgres
DATABASE_URL=postgres://pumpdragon:pumpdragon@db:5432/pumpdragon
# For local tests only (docker-compose.test.yml):
DATABASE_URL_TEST=postgres://pumpdragon:pumpdragon@localhost:5433/pumpdragon_test

# Behavior
TIMEZONE=America/Chicago
RECAP_TIME=08:00
USER_COOLDOWN_SECONDS=5

# Conversational roast target (Feature 3). Optional — unset = no roasting, pure hype.
# ROAST_USER_ID is the Discord user id the dragon affectionately ribs; ROAST_NICKNAME is what it calls them.
ROAST_USER_ID=
ROAST_NICKNAME=magic
